#include "lcd_spi_sw.h"

#include "at32f435_437_wk_config.h"
#include "wk_system.h"

#define LCD_SPI_SW_DELAY_US 1U

static uint8_t lcd_spi_sw_sample_on_falling = 0;
static uint8_t lcd_spi_sw_9bit_mode = 0;

static void lcd_spi_sw_delay(void)
{
  wk_delay_us(LCD_SPI_SW_DELAY_US);
}

static void lcd_spi_sw_sclk_low(void)
{
  gpio_bits_reset(LCD_SCLK_GPIO_PORT, LCD_SCLK_PIN);
}

static void lcd_spi_sw_sclk_high(void)
{
  gpio_bits_set(LCD_SCLK_GPIO_PORT, LCD_SCLK_PIN);
}

static void lcd_spi_sw_sda_high(void)
{
  gpio_bits_set(LCD_SDA_GPIO_PORT, LCD_SDA_PIN);
}

static void lcd_spi_sw_sda_low(void)
{
  gpio_bits_reset(LCD_SDA_GPIO_PORT, LCD_SDA_PIN);
}

static int lcd_spi_sw_sda_read(void)
{
  return (gpio_input_data_bit_read(LCD_SDA_GPIO_PORT, LCD_SDA_PIN) == SET) ? 1 : 0;
}

static void lcd_spi_sw_csn_low(void)
{
  gpio_bits_reset(LCD_NCS_GPIO_PORT, LCD_NCS_PIN);
}

static void lcd_spi_sw_csn_high(void)
{
  gpio_bits_set(LCD_NCS_GPIO_PORT, LCD_NCS_PIN);
}

static void lcd_spi_sw_dcx_cmd(void)
{
  gpio_bits_reset(LCD_DCX_GPIO_PORT, LCD_DCX_PIN);
}

static void lcd_spi_sw_dcx_data(void)
{
  gpio_bits_set(LCD_DCX_GPIO_PORT, LCD_DCX_PIN);
}

static void lcd_spi_sw_sda_mode_output(void)
{
  gpio_init_type gpio_init_struct;
  gpio_default_para_init(&gpio_init_struct);
  gpio_init_struct.gpio_drive_strength = GPIO_DRIVE_STRENGTH_MODERATE;
  gpio_init_struct.gpio_out_type = GPIO_OUTPUT_PUSH_PULL;
  gpio_init_struct.gpio_mode = GPIO_MODE_OUTPUT;
  gpio_init_struct.gpio_pins = LCD_SDA_PIN;
  gpio_init_struct.gpio_pull = GPIO_PULL_NONE;
  gpio_init(LCD_SDA_GPIO_PORT, &gpio_init_struct);
}

static void lcd_spi_sw_sda_mode_input(void)
{
  gpio_init_type gpio_init_struct;
  gpio_default_para_init(&gpio_init_struct);
  gpio_init_struct.gpio_mode = GPIO_MODE_INPUT;
  gpio_init_struct.gpio_pins = LCD_SDA_PIN;
  gpio_init_struct.gpio_pull = GPIO_PULL_NONE;
  gpio_init(LCD_SDA_GPIO_PORT, &gpio_init_struct);
}

static void lcd_spi_sw_write_bit(uint8_t bit)
{
  lcd_spi_sw_sclk_low();
  if(bit)
  {
    lcd_spi_sw_sda_high();
  }
  else
  {
    lcd_spi_sw_sda_low();
  }
  lcd_spi_sw_delay();
  lcd_spi_sw_sclk_high();
  lcd_spi_sw_delay();
  lcd_spi_sw_sclk_low();
  lcd_spi_sw_delay();
}

static uint8_t lcd_spi_sw_read_bit(void)
{
  uint8_t bit;
  if(lcd_spi_sw_sample_on_falling)
  {
    lcd_spi_sw_sclk_low();
    lcd_spi_sw_delay();
    lcd_spi_sw_sclk_high();
    lcd_spi_sw_delay();
    lcd_spi_sw_sclk_low();
    lcd_spi_sw_delay();
    bit = (uint8_t)lcd_spi_sw_sda_read();
    lcd_spi_sw_delay();
  }
  else
  {
    lcd_spi_sw_sclk_low();
    lcd_spi_sw_delay();
    lcd_spi_sw_sclk_high();
    lcd_spi_sw_delay();
    bit = (uint8_t)lcd_spi_sw_sda_read();
    lcd_spi_sw_sclk_low();
    lcd_spi_sw_delay();
  }
  return bit;
}

static void lcd_spi_sw_write_byte(uint8_t byte)
{
  uint8_t mask;
  for(mask = 0x80U; mask != 0U; mask >>= 1)
  {
    lcd_spi_sw_write_bit((byte & mask) ? 1U : 0U);
  }
}

static void lcd_spi_sw_write_9bit(uint8_t dc_bit, uint8_t byte)
{
  lcd_spi_sw_write_bit(dc_bit ? 1U : 0U);
  lcd_spi_sw_write_byte(byte);
}

static uint8_t lcd_spi_sw_read_byte(void)
{
  uint8_t i;
  uint8_t v = 0;
  for(i = 0; i < 8U; i++)
  {
    v <<= 1;
    v |= lcd_spi_sw_read_bit();
  }
  return v;
}

void lcd_spi_sw_init(void)
{
  gpio_init_type gpio_init_struct;
  gpio_default_para_init(&gpio_init_struct);

  gpio_init_struct.gpio_drive_strength = GPIO_DRIVE_STRENGTH_MODERATE;
  gpio_init_struct.gpio_out_type = GPIO_OUTPUT_PUSH_PULL;
  gpio_init_struct.gpio_mode = GPIO_MODE_OUTPUT;
  gpio_init_struct.gpio_pull = GPIO_PULL_NONE;

  gpio_init_struct.gpio_pins = LCD_SCLK_PIN;
  gpio_init(LCD_SCLK_GPIO_PORT, &gpio_init_struct);

  gpio_init_struct.gpio_pins = LCD_DCX_PIN;
  gpio_init(LCD_DCX_GPIO_PORT, &gpio_init_struct);

  gpio_init_struct.gpio_pins = LCD_NCS_PIN;
  gpio_init(LCD_NCS_GPIO_PORT, &gpio_init_struct);

  gpio_init_struct.gpio_pins = LCD_RESET_PIN;
  gpio_init(LCD_RESET_GPIO_PORT, &gpio_init_struct);

  lcd_spi_sw_sda_mode_output();

  lcd_spi_sw_csn_high();
  lcd_spi_sw_sclk_low();
  lcd_spi_sw_dcx_data();
  lcd_spi_sw_sda_high();
}

void lcd_spi_sw_reset_pulse(uint32_t low_ms, uint32_t high_ms)
{
  gpio_bits_reset(LCD_RESET_GPIO_PORT, LCD_RESET_PIN);
  wk_delay_ms(low_ms);
  gpio_bits_set(LCD_RESET_GPIO_PORT, LCD_RESET_PIN);
  wk_delay_ms(high_ms);
}

void lcd_spi_sw_write_cmd(uint8_t cmd)
{
  lcd_spi_sw_sda_mode_output();

  lcd_spi_sw_csn_low();
  if(lcd_spi_sw_9bit_mode)
  {
    lcd_spi_sw_dcx_cmd();
    lcd_spi_sw_write_9bit(0, cmd);
  }
  else
  {
    lcd_spi_sw_dcx_cmd();
    lcd_spi_sw_write_byte(cmd);
  }
  lcd_spi_sw_csn_high();
}

void lcd_spi_sw_write_cmd_data(uint8_t cmd, const uint8_t *data, uint32_t len)
{
  uint32_t i;

  lcd_spi_sw_sda_mode_output();

  lcd_spi_sw_csn_low();
  if(lcd_spi_sw_9bit_mode)
  {
    lcd_spi_sw_dcx_cmd();
    lcd_spi_sw_write_9bit(0, cmd);
  }
  else
  {
    lcd_spi_sw_dcx_cmd();
    lcd_spi_sw_write_byte(cmd);
  }

  if((data != 0) && (len != 0U))
  {
    for(i = 0; i < len; i++)
    {
      if(lcd_spi_sw_9bit_mode)
      {
        lcd_spi_sw_dcx_cmd();
        lcd_spi_sw_write_9bit(1, data[i]);
      }
      else
      {
        lcd_spi_sw_dcx_data();
        lcd_spi_sw_write_byte(data[i]);
      }
    }
  }
  lcd_spi_sw_csn_high();
}

void lcd_spi_sw_set_sample_on_falling(uint8_t enable)
{
  lcd_spi_sw_sample_on_falling = enable ? 1U : 0U;
}

void lcd_spi_sw_set_9bit_mode(uint8_t enable)
{
  lcd_spi_sw_9bit_mode = enable ? 1U : 0U;
}

int lcd_spi_sw_read_reg(uint8_t cmd, uint8_t *data, uint32_t len, uint32_t dummy_bits)
{
  uint32_t i;
  uint32_t d;

  if((data == 0) && (len != 0U))
  {
    return 0;
  }

  lcd_spi_sw_sda_mode_output();

  lcd_spi_sw_csn_low();
  lcd_spi_sw_dcx_cmd();
  if(lcd_spi_sw_9bit_mode)
  {
    lcd_spi_sw_write_9bit(0, cmd);
  }
  else
  {
    lcd_spi_sw_write_byte(cmd);
  }

  if(!lcd_spi_sw_9bit_mode)
  {
    lcd_spi_sw_dcx_data();
  }
  lcd_spi_sw_sda_mode_input();

  for(d = 0; d < dummy_bits; d++)
  {
    (void)lcd_spi_sw_read_bit();
  }

  for(i = 0; i < len; i++)
  {
    data[i] = lcd_spi_sw_read_byte();
  }

  lcd_spi_sw_csn_high();
  lcd_spi_sw_sda_mode_output();
  lcd_spi_sw_sda_high();

  return 1;
}

int lcd_spi_sw_write_pixels_rgb565(uint8_t cmd, const uint16_t *pixels, uint32_t pixel_count)
{
  uint32_t i;

  if((pixels == 0) && (pixel_count != 0U))
  {
    return 0;
  }

  lcd_spi_sw_sda_mode_output();

  lcd_spi_sw_csn_low();
  lcd_spi_sw_dcx_cmd();
  if(lcd_spi_sw_9bit_mode)
  {
    lcd_spi_sw_write_9bit(0, cmd);
  }
  else
  {
    lcd_spi_sw_write_byte(cmd);
  }

  if(!lcd_spi_sw_9bit_mode)
  {
    lcd_spi_sw_dcx_data();
  }

  for(i = 0; i < pixel_count; i++)
  {
    uint16_t px = pixels[i];
    uint8_t hi = (uint8_t)(px >> 8);
    uint8_t lo = (uint8_t)(px & 0xFFU);

    if(lcd_spi_sw_9bit_mode)
    {
      lcd_spi_sw_dcx_cmd();
      lcd_spi_sw_write_9bit(1, hi);
      lcd_spi_sw_dcx_cmd();
      lcd_spi_sw_write_9bit(1, lo);
    }
    else
    {
      lcd_spi_sw_write_byte(hi);
      lcd_spi_sw_write_byte(lo);
    }
  }

  lcd_spi_sw_csn_high();
  lcd_spi_sw_sda_mode_output();
  lcd_spi_sw_sda_high();

  return 1;
}

int lcd_spi_sw_read_reg_auto(uint8_t cmd, uint8_t *data, uint32_t len)
{
  uint32_t dummy_bits = 0U;
  if((len == 3U) || (len == 4U))
  {
    dummy_bits = 1U;
  }
  return lcd_spi_sw_read_reg(cmd, data, len, dummy_bits);
}

int lcd_spi_sw_read_bits(uint8_t cmd, uint8_t dcx_is_data, uint8_t *bits, uint32_t bit_len, uint32_t dummy_bits)
{
  uint32_t i;
  uint32_t d;

  if((bits == 0) && (bit_len != 0U))
  {
    return 0;
  }

  lcd_spi_sw_sda_mode_output();

  lcd_spi_sw_csn_low();
  lcd_spi_sw_dcx_cmd();
  lcd_spi_sw_write_byte(cmd);

  if(dcx_is_data)
  {
    lcd_spi_sw_dcx_data();
  }
  else
  {
    lcd_spi_sw_dcx_cmd();
  }

  lcd_spi_sw_sda_mode_input();

  for(d = 0; d < dummy_bits; d++)
  {
    (void)lcd_spi_sw_read_bit();
  }

  for(i = 0; i < bit_len; i++)
  {
    bits[i] = lcd_spi_sw_read_bit();
  }

  lcd_spi_sw_csn_high();
  lcd_spi_sw_sda_mode_output();
  lcd_spi_sw_sda_high();

  return 1;
}
