#ifndef __LCD_SPI_SW_H
#define __LCD_SPI_SW_H

#ifdef __cplusplus
extern "C" {
#endif

#include <stdint.h>

void lcd_spi_sw_init(void);
void lcd_spi_sw_reset_pulse(uint32_t low_ms, uint32_t high_ms);
void lcd_spi_sw_write_cmd(uint8_t cmd);
void lcd_spi_sw_write_cmd_data(uint8_t cmd, const uint8_t *data, uint32_t len);
void lcd_spi_sw_set_sample_on_falling(uint8_t enable);
void lcd_spi_sw_set_9bit_mode(uint8_t enable);
int lcd_spi_sw_write_pixels_rgb565(uint8_t cmd, const uint16_t *pixels, uint32_t pixel_count);
int lcd_spi_sw_read_reg(uint8_t cmd, uint8_t *data, uint32_t len, uint32_t dummy_bits);
int lcd_spi_sw_read_reg_auto(uint8_t cmd, uint8_t *data, uint32_t len);
int lcd_spi_sw_read_bits(uint8_t cmd, uint8_t dcx_is_data, uint8_t *bits, uint32_t bit_len, uint32_t dummy_bits);

#ifdef __cplusplus
}
#endif

#endif
